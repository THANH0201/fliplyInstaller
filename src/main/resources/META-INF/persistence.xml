<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             version="3.0"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    <persistence-unit name="FliplyDbUnit" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>model.entity.User</class>
        <class>model.entity.ClassModel</class>
        <class>model.entity.Flashcard</class>
        <class>model.entity.FlashcardSet</class>
        <class>model.entity.Quiz</class>
        <class>model.entity.QuizDetails</class>
        <class>model.entity.ClassDetails</class>
        <class>model.entity.Study</class>
